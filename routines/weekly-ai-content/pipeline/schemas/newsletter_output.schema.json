{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alanvaa06/battle_tested_skills/specs/newsletter_output.schema.json",
  "title": "newsletter_output",
  "description": "Output contract for email-newsletter-ai skill when pipeline_mode=true. Consumes research_output and produces newsletter content ready for n8n HTML rendering and email distribution.",
  "type": "object",
  "required": ["newsletter_output"],
  "properties": {
    "newsletter_output": {
      "type": "object",
      "required": ["meta", "section_1", "section_2", "editorial_notes"],
      "additionalProperties": false,
      "properties": {
        "meta": {
          "type": "object",
          "required": ["generated_at", "week_start", "week_end", "week_ref", "language", "bullet_count", "estimated_read_time_seconds"],
          "properties": {
            "generated_at":                 { "type": "string", "format": "date-time" },
            "week_start":                   { "type": "string", "format": "date" },
            "week_end":                     { "type": "string", "format": "date" },
            "week_ref":                     { "type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}$" },
            "language":                     { "type": "string", "examples": ["English", "Spanish (Mexico)"] },
            "bullet_count":                 { "type": "integer", "minimum": 12, "maximum": 20 },
            "estimated_read_time_seconds":  { "type": "integer", "minimum": 0, "description": "Total word count across all text fields / 4." }
          }
        },
        "section_1": {
          "type": "object",
          "required": ["intro", "featured_story"],
          "properties": {
            "intro": {
              "type": "string",
              "minLength": 100,
              "description": "2-3 sentence editorial introduction as a single string. Must not start with 'This week' or 'Welcome to'."
            },
            "featured_story": {
              "type": "object",
              "required": ["actor", "headline", "body", "forward_tension"],
              "properties": {
                "actor":            { "type": "string", "description": "Company, lab, or product subject of the featured story." },
                "headline":         { "type": "string", "description": "Sharp specific headline, no period." },
                "body":             { "type": "string", "minLength": 400, "maxLength": 900, "description": "80-120 word paragraph. Answers: what happened, why it matters strategically, what to carry forward." },
                "forward_tension":  { "type": "string", "description": "Closing sentence that pulls reader into the bullet list — question, unresolved signal, or to-watch pointer." }
              }
            }
          }
        },
        "section_2": {
          "type": "object",
          "required": ["bullets"],
          "properties": {
            "bullets": {
              "type": "array",
              "minItems": 12,
              "maxItems": 20,
              "items": {
                "type": "object",
                "required": ["rank", "label", "actor", "fact", "implication", "repo_meta"],
                "properties": {
                  "rank":         { "type": "integer", "minimum": 1 },
                  "label":        { "type": "string", "enum": ["MODEL", "AGENT", "DEV", "REPO", "SIGNAL", "WATCH"] },
                  "actor":        { "type": "string" },
                  "fact":         { "type": "string", "description": "One sentence — specific development with date or number where available." },
                  "implication":  { "type": "string", "description": "One sentence — practitioner-lens implication. Must be distinct from fact." },
                  "repo_meta": {
                    "type": "object",
                    "description": "Populated only when label is REPO. Otherwise owner_repo=null, both ints=0.",
                    "required": ["owner_repo", "stars_total", "stars_weekly_delta"],
                    "properties": {
                      "owner_repo":         { "type": ["string", "null"] },
                      "stars_total":        { "type": "integer", "minimum": 0 },
                      "stars_weekly_delta": { "type": "integer" }
                    }
                  }
                }
              }
            }
          }
        },
        "editorial_notes": {
          "type": "object",
          "required": ["dominant_theme", "market_mood", "ranking_rationale", "items_included", "items_excluded"],
          "properties": {
            "dominant_theme":     { "type": "string", "description": "Carried from research_output.narrative.dominant_theme" },
            "market_mood":        { "type": "string", "description": "Carried from research_output.narrative.market_mood" },
            "ranking_rationale":  { "type": "string", "description": "2-3 sentences on why the top 3 bullets are ranked where they are. Used for analytics, not displayed." },
            "items_included":     { "type": "integer", "minimum": 12, "description": "Equals section_2.bullets length." },
            "items_excluded":     { "type": "integer", "minimum": 0, "description": "Items from research_output evaluated but not included." },
            "exclusion_reason":   { "type": "string", "description": "One sentence — what was cut and why." }
          }
        }
      }
    }
  }
}
