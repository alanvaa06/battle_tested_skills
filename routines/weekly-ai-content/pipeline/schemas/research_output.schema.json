{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alanvaa06/battle_tested_skills/specs/research_output.schema.json",
  "title": "research_output",
  "description": "Output contract for weekly-ai-research skill when pipeline_mode=true. Consumed by email-newsletter-ai and linkedin-alan-post via coordinator.",
  "type": "object",
  "required": ["research_output"],
  "properties": {
    "research_output": {
      "type": "object",
      "required": ["meta", "narrative", "sections"],
      "additionalProperties": false,
      "properties": {
        "meta": {
          "type": "object",
          "required": ["week_start", "week_end", "week_ref", "language", "generated_at", "research_window_days"],
          "properties": {
            "week_start": { "type": "string", "format": "date", "description": "YYYY-MM-DD, inclusive" },
            "week_end":   { "type": "string", "format": "date", "description": "YYYY-MM-DD, inclusive" },
            "week_ref":   { "type": "string", "pattern": "^[0-9]{4}-W[0-9]{2}$", "description": "ISO week e.g. 2026-W20" },
            "language":   { "type": "string", "examples": ["English", "Spanish (Mexico)"] },
            "region_focus": { "type": "string", "examples": ["Global", "Latin America / Mexico"] },
            "research_window_days": { "type": "integer", "minimum": 1, "maximum": 30 },
            "generated_at": { "type": "string", "format": "date-time" },
            "items_evaluated": { "type": "integer", "minimum": 0, "description": "Total candidate items scanned before ranking" }
          }
        },
        "narrative": {
          "type": "object",
          "required": [
            "executive_summary", "dominant_theme", "market_mood", "market_mood_rationale",
            "biggest_move", "competitive_frontier", "open_source_signal",
            "strategic_takeaways", "to_watch", "content_angles"
          ],
          "properties": {
            "executive_summary": {
              "type": "string",
              "minLength": 200,
              "description": "4-7 sentences, single paragraph, leads with dominant theme. No bullets."
            },
            "dominant_theme": {
              "type": "string",
              "description": "One declarative sentence naming the week's pattern across all four pillars."
            },
            "market_mood": {
              "type": "string",
              "enum": ["bullish", "neutral", "cautious", "bearish", "frothy", "consolidating"],
              "description": "Industry sentiment read for the week."
            },
            "market_mood_rationale": {
              "type": "string",
              "description": "1-2 sentences explaining the mood call with specific evidence."
            },
            "biggest_move": {
              "type": "object",
              "required": ["actor", "move", "signal"],
              "properties": {
                "actor":  { "type": "string", "description": "Company / lab / project that made the move" },
                "move":   { "type": "string", "description": "Specific action taken — release, deal, policy, pricing change. Include date." },
                "signal": { "type": "string", "description": "What this move signals about competitive strategy or industry direction." },
                "date":   { "type": "string", "format": "date" }
              }
            },
            "competitive_frontier": {
              "type": "string",
              "description": "1-2 sentences on where the frontier shifted — capability, distribution, governance, ecosystem."
            },
            "open_source_signal": {
              "type": "string",
              "description": "1-2 sentences on the OSS pattern that reflects or contradicts lab behavior."
            },
            "strategic_takeaways": {
              "type": "array",
              "minItems": 2,
              "maxItems": 4,
              "items": {
                "type": "object",
                "required": ["headline", "explanation"],
                "properties": {
                  "headline":    { "type": "string", "description": "Bolded one-sentence takeaway." },
                  "explanation": { "type": "string", "description": "1-3 sentences of context." }
                }
              }
            },
            "to_watch": {
              "type": "array",
              "minItems": 2,
              "maxItems": 4,
              "items": {
                "type": "object",
                "required": ["item", "type"],
                "properties": {
                  "item":     { "type": "string", "description": "Specific event, release, or open question." },
                  "type":     { "type": "string", "enum": ["event", "release", "open_question", "rumor"] },
                  "date_hint": { "type": "string", "description": "Optional — when it lands or resolves." }
                }
              }
            },
            "content_angles": {
              "type": "object",
              "required": ["newsletter_angle", "linkedin_hook"],
              "properties": {
                "newsletter_angle": {
                  "type": "string",
                  "description": "Editorial frame for newsletter intro — point of view, not summary."
                },
                "linkedin_hook": {
                  "type": "string",
                  "description": "Pre-drafted hook line for LinkedIn. Must be: diagnostic question, contrarian reframe, news-to-implication, or data-first provocation."
                },
                "linkedin_pattern_recommendation": {
                  "type": "string",
                  "enum": ["A", "B", "C", "E"],
                  "description": "Coordinator recommendation. Pattern D (milestone) excluded."
                }
              }
            }
          }
        },
        "sections": {
          "type": "object",
          "required": ["frontier_models", "agent_capabilities", "developer_environment", "trending_repos"],
          "properties": {
            "frontier_models": {
              "type": "object",
              "required": ["anthropic", "openai", "google", "xai"],
              "properties": {
                "anthropic": { "$ref": "#/$defs/lab_items" },
                "openai":    { "$ref": "#/$defs/lab_items" },
                "google":    { "$ref": "#/$defs/lab_items" },
                "xai":       { "$ref": "#/$defs/lab_items" },
                "other":     { "$ref": "#/$defs/lab_items", "description": "DeepSeek, Qwen, Mistral, Meta, Cohere — only when notable." }
              }
            },
            "agent_capabilities": {
              "type": "object",
              "required": ["items", "pattern"],
              "properties": {
                "items": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/dev_item" }
                },
                "pattern": {
                  "type": "string",
                  "description": "One-sentence synthesis of what this week's agent moves signal."
                }
              }
            },
            "developer_environment": {
              "type": "object",
              "required": ["items"],
              "properties": {
                "items": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/dev_item" }
                }
              }
            },
            "trending_repos": {
              "type": "object",
              "required": ["repos", "hot_categories"],
              "properties": {
                "repos": {
                  "type": "array",
                  "minItems": 5,
                  "items": {
                    "type": "object",
                    "required": ["owner_repo", "stars_total", "stars_weekly_delta", "description", "category", "source_url"],
                    "properties": {
                      "owner_repo":         { "type": "string", "pattern": "^[^/]+/[^/]+$" },
                      "stars_total":        { "type": "integer", "minimum": 0 },
                      "stars_weekly_delta": { "type": "integer" },
                      "description":        { "type": "string" },
                      "category":           {
                        "type": "string",
                        "enum": ["skills", "agent_framework", "coding_agent", "multi_agent", "infra", "workflow", "local_inference", "other"]
                      },
                      "source_url":         { "type": "string", "format": "uri" }
                    }
                  }
                },
                "hot_categories": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 6,
                  "items": {
                    "type": "object",
                    "required": ["category", "aggregate_stars"],
                    "properties": {
                      "category":        { "type": "string" },
                      "aggregate_stars": { "type": "integer", "minimum": 0 }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "lab_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fact", "date", "source_url"],
        "properties": {
          "fact":      { "type": "string", "description": "What shipped — be specific. Include benchmark / pricing if available." },
          "date":      { "type": "string", "format": "date" },
          "category":  { "type": "string", "enum": ["model_release", "capability_update", "pricing", "safety_policy", "infrastructure_deal", "enterprise_feature"] },
          "source_url": { "type": "string", "format": "uri", "description": "Primary-source URL — official blog, changelog, release notes." },
          "metric":    { "type": "string", "description": "Optional benchmark or KPI value tied to the fact." }
        }
      }
    },
    "dev_item": {
      "type": "object",
      "required": ["fact"],
      "properties": {
        "fact":       { "type": "string" },
        "actor":      { "type": "string" },
        "date":       { "type": "string", "format": "date" },
        "source_url": { "type": "string", "format": "uri" }
      }
    }
  }
}
